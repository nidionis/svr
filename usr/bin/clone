#!/bin/bash
clone () 
{ 
	URL=git@github.com:
	PROFIL_NAME=nidionis
	DEFAULT_ADDR=""
    if [ $# -ne "1" ]; then
        PROFIL_NAME="$1";
        PROJECT_NAME="$2";
        git clone --recurse-submodules $URL/$PROFIL_NAME/$PROJECT_NAME.git;
    else
        PROJECT_NAME="$1";
        git clone --recurse-submodules $URL/$PROFIL_NAME/$PROJECT_NAME.git;
    fi
}
clone "$@"

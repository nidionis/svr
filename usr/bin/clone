#!/bin/bash
clone () 
{ 
	DEFAULT_ADDR=""
    if [ $# -ne "1" ]; then
        PROFIL_NAME="$1";
        PROJECT_NAME="$2";
        git clone --recurse-submodules ssh://git@0.tcp.eu.ngrok.io:18869/$PROFIL_NAME/$PROJECT_NAME.git;
    else
        PROJECT_NAME="$1";
        git clone --recurse-submodules ssh://git@0.tcp.eu.ngrok.io:18869/painpain/$PROJECT_NAME.git;
    fi
}
clone "$@"

#!/usr/bin/bash

if [ "$#" -lt 1 ] || [ "$#" -gt 3 ]; then
    echo "Usage: $0 arg1 [arg2] [arg3]"
    exit 1
fi

VPS=${1:-"$IAMUTOPIST"}
USER=${2:-"root"}
VPS_PORT=${3:-"443"}
HOST_PORT=${4:-"3000"}

echo """
runs:
ssh -N -R $VPS_PORT:localhost:$HOST_PORT $USER@$VPS
"""

ssh -N -R $VPS_PORT:localhost:$HOST_PORT $USER@$VPS
